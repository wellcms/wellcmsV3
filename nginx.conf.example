# WellCMS 3.0 Nginx 配置参考
# ⚠️ 重要提示：请将下方所有 /www/wwwroot/wellcms/ 路径替换为你服务器的实际部署路径！

server {
    listen 80;
    server_name your-domain.com;

    # ⚠️ 修改此处为你服务器的实际站点根目录（必须指向 public/ 目录）
    root /www/wwwroot/wellcms/public;
    index index.php index.html;

    # ------------------------------------------------------------------------
    # 1) 插件静态资源
    # ------------------------------------------------------------------------
    location ^~ /plugins/ {
        # ⚠️ 修改为你的实际部署路径
        alias /www/wwwroot/wellcms/plugins/;
        access_log off;
        expires 30d;
    }

    # ------------------------------------------------------------------------
    # 2) 主题静态资源
    # ------------------------------------------------------------------------
    location ^~ /themes/ {
        # ⚠️ 修改为你的实际部署路径
        alias /www/wwwroot/wellcms/themes/;
        access_log off;
        expires 30d;
    }

    # ------------------------------------------------------------------------
    # 3) 视图静态资源
    # ------------------------------------------------------------------------
    location ^~ /views/ {
        # ⚠️ 修改为你的实际部署路径
        alias /www/wwwroot/wellcms/app/views/;
        access_log off;
        expires 30d;
    }

    # ------------------------------------------------------------------------
    # 4) 上传文件静态资源
    # ------------------------------------------------------------------------
    location ^~ /upload/ {
        # ⚠️ 修改为你的实际部署路径
        alias /www/wwwroot/wellcms/storage/upload/;
        access_log off;
        expires 30d;
    }

    # ------------------------------------------------------------------------
    # 5) 程序静态资源（runtime 打包 JS/CSS 等）
    # ------------------------------------------------------------------------
    location ^~ /static/ {
        # ⚠️ 修改为你的实际部署路径
        alias /www/wwwroot/wellcms/public/static/;
        access_log off;
        expires 30d;
    }

    # ------------------------------------------------------------------------
    # 6) 伪静态规则（兼容 3 种 URL 风格）
    #    user-login.html | /user/login.html | /user/login
    # ------------------------------------------------------------------------
    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ /\.ht {
        deny all;
    }
}
