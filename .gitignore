# WellCMS 3.0 Git Ignore

# ------------------------------------------------------------------------
# 运行时文件（保留目录结构通过 .gitkeep）
# ------------------------------------------------------------------------
/storage/logs/*
!/storage/logs/.gitkeep

/storage/tmp/*
!/storage/tmp/.gitkeep

/storage/upload/*
!/storage/upload/.gitkeep

# ------------------------------------------------------------------------
# 安装锁定文件（安装后自动生成，不应进入版本库）
# ------------------------------------------------------------------------
/install/install.lock

# ------------------------------------------------------------------------
# 配置备份/副本（防止误提交带敏感信息的副本）
# ------------------------------------------------------------------------
config/*.copy.php
config/*.backup.php
config/*.old.php
config/*.orig.php

# ------------------------------------------------------------------------
# IDE 与编辑器
# ------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ------------------------------------------------------------------------
# 操作系统文件
# ------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------------------
# 日志与调试
# ------------------------------------------------------------------------
*.log
error_log
access_log

# ------------------------------------------------------------------------
# 依赖目录
# ------------------------------------------------------------------------
node_modules/
vendor/

# 压缩包与临时文件
# ------------------------------------------------------------------------
*.zip
*.tar.gz
*.rar
*.tmp
*.cache
